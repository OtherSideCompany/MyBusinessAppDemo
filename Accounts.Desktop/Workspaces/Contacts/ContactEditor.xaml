<UserControl x:Class="Accounts.Desktop.Workspaces.Contacts.ContactEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Accounts.Desktop.Workspaces.Contacts"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls;assembly=OtherSideCore.Wpf"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls;assembly=OtherSideCore.Wpf"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions;assembly=OtherSideCore.Wpf" 
             xmlns:editor="clr-namespace:OtherSideCore.Wpf.UserControls.Editor;assembly=OtherSideCore.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto" />
         <RowDefinition Height="Auto" />
         <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
       
      <osc_customcontrols:InfoPanelCategory Grid.Row="0" Margin="0,8,0,0"
                                            InfoPanelCategory_HeaderName="Infos"
                                            InfoPanelCategory_IsExpanded="True"
                                            InfoPanelCategory_DisplaySeparator="True"
                                            IsEnabled="{Binding IsEnabled}">

         <editor:DomainObjectEditorPropertiesEdition />

      </osc_customcontrols:InfoPanelCategory>

      <osc_customcontrols:InfoPanelCategory Grid.Row="1" Margin="0,8,0,0"
                                            InfoPanelCategory_HeaderName="Références"
                                            InfoPanelCategory_IsExpanded="True"
                                            InfoPanelCategory_DisplaySeparator="True">

         <editor:DomainObjectReferencesEditor DataContext="{Binding DomainObjectReferencesEditorViewModel}" 
                                              DomainObjectReferencesEditor_DataTemplateSelector="{StaticResource ReferenceTypeTemplateSelector}"/>

      </osc_customcontrols:InfoPanelCategory>

      <osc_customcontrols:InfoPanelCategory Grid.Row="2" Margin="0,8,0,0"
                                      InfoPanelCategory_HeaderName="Historique"
                                      InfoPanelCategory_IsExpanded="True"
                                      InfoPanelCategory_DisplaySeparator="True">

         <editor:DomainObjectHistoryView DataContext="{Binding DomainObjectViewModel}" />

      </osc_customcontrols:InfoPanelCategory>
   </Grid>
</UserControl>
