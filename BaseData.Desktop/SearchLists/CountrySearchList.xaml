<UserControl x:Class="BaseData.Desktop.SearchLists.CountrySearchList"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BaseData.Desktop.SearchLists"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls;assembly=OtherSideCore.Wpf"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls;assembly=OtherSideCore.Wpf"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions;assembly=OtherSideCore.Wpf" 
             xmlns:browser="clr-namespace:OtherSideCore.Wpf.UserControls.Browser;assembly=OtherSideCore.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
   <Grid>
      <browser:BrowserDomainObjectSearchListView>
         <browser:BrowserDomainObjectSearchListView.BrowserDomainObjectSearchListView_GridView>
            <GridView>

               <osc_customcontrols:SortableGridViewColumn Width="200" Header="Libellé" 
                                                          SortPropertyName="DomainObjectSearchResult.Name" 
                                                          DisplayMemberBinding="{Binding DomainObjectSearchResult.Name}"/>

               <osc_customcontrols:SortableGridViewColumn Width="200" Header="Code alpha 2 digits" 
                                                          SortPropertyName="DomainObjectSearchResult.Alpha2Code"
                                                          DisplayMemberBinding="{Binding DomainObjectSearchResult.Alpha2Code}"/>

               <osc_customcontrols:SortableGridViewColumn Width="200" Header="Code alpha 3 digits" 
                                                          SortPropertyName="DomainObjectSearchResult.Alpha3Code"
                                                          DisplayMemberBinding="{Binding DomainObjectSearchResult.Alpha3Code}"/>

               <osc_customcontrols:SortableGridViewColumn Width="200" Header="Code numérique" 
                                                          SortPropertyName="DomainObjectSearchResult.NumericCode"
                                                          DisplayMemberBinding="{Binding DomainObjectSearchResult.NumericCode}"/>

            </GridView>
         </browser:BrowserDomainObjectSearchListView.BrowserDomainObjectSearchListView_GridView>
      </browser:BrowserDomainObjectSearchListView>
   </Grid>
</UserControl>
