<UserControl x:Class="BaseData.Desktop.Workspaces.Permissions.UserRoleDetailsEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BaseData.Desktop.Workspaces.Permissions"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls;assembly=OtherSideCore.Wpf"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls;assembly=OtherSideCore.Wpf"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions;assembly=OtherSideCore.Wpf" 
             xmlns:modules="clr-namespace:OtherSideCore.Wpf.UserControls.Modules;assembly=OtherSideCore.Wpf" 
             xmlns:editor="clr-namespace:OtherSideCore.Wpf.UserControls.Editor;assembly=OtherSideCore.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
   <Grid>
      <Border>
         <Grid>
            <Grid.RowDefinitions>
               <RowDefinition Height="Auto" />
               <RowDefinition Height="Auto" />
               <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <modules:ModuleHeader Grid.Row="0"
                                  ModuleHeader_IconGeometry="{StaticResource icon_pencil-outline}"
                                  ModuleHeader_Name="Édition des permissions" 
                                  ModuleHeader_HasUnsavedChanges="{Binding HasUnsavedChanges}" />

            <editor:SaveCancelChangesAsyncView Grid.RowSpan="3"
                                               Visibility="{Binding HasUnsavedChanges, Converter={StaticResource BoolToVisibleOrCollapsed}}"
                                               SaveCancelChangesAsyncView_SaveCommand="{Binding SaveChangesAsyncCommand}"
                                               SaveCancelChangesAsyncView_CancelCommand="{Binding CancelChangesAsyncCommand}"
                                               Margin="10"/>

            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,16,0,0">

               <Grid>
                  <Grid.RowDefinitions>
                     <RowDefinition Height="Auto" />
                     <RowDefinition Height="Auto" />
                  </Grid.RowDefinitions>

                  <WrapPanel Orientation="Horizontal">

                     <osc_customcontrols:SvgImageTextButton Height="32" HorizontalAlignment="Left"
                                                            SvgImageTextButton_Text="Tout sélectionner" 
                                                            SvgImageTextButton_IconGeometry="{StaticResource icon_check}"
                                                            Command="{Binding CheckAllPermissionsCommand}"/>

                     <osc_customcontrols:SvgImageTextButton Height="32" HorizontalAlignment="Left" Margin="4,0,0,0"
                                                            SvgImageTextButton_Text="Tout désélectionner" 
                                                            SvgImageTextButton_IconGeometry="{StaticResource icon_cancel}"
                                                            Command="{Binding UncheckAllPermissionsCommand}"/>

                  </WrapPanel>                 

                  <DataGrid Grid.Row="1" Margin="0,16,0,0" 
                            Style="{StaticResource OtherSideCoreDataGrid}"
                            ItemsSource="{Binding AvailableUserRolePermissionViewModels}"
                            osc_extensions:DataGridExtension.ThumbColor="{StaticResource Green}"
                            osc_extensions:DataGridExtension.HeaderForegroundColor="{StaticResource Green_Dark}">

                     <DataGrid.Columns>

                        <DataGridTemplateColumn Header="Permission">
                           <DataGridTemplateColumn.CellTemplate>
                              <DataTemplate>
                                 <osc_customcontrols:ClickSelectTextBox Text="{Binding DisplayName}" IsReadOnly="True" />
                              </DataTemplate>
                           </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Accès" Width="110" >
                           <DataGridTemplateColumn.CellTemplate>
                              <DataTemplate>
                                 <CheckBox Style="{StaticResource EditorCheckBox}" 
                                           IsChecked="{Binding CanAccess, UpdateSourceTrigger=PropertyChanged}" 
                                           HorizontalAlignment="Center"/>
                              </DataTemplate>
                           </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Lecture" Width="110" >
                           <DataGridTemplateColumn.CellTemplate>
                              <DataTemplate>
                                 <CheckBox Style="{StaticResource EditorCheckBox}" 
                                           IsChecked="{Binding CanRead, UpdateSourceTrigger=PropertyChanged}" 
                                           HorizontalAlignment="Center"/>
                              </DataTemplate>
                           </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Ajout" Width="110">
                           <DataGridTemplateColumn.CellTemplate>
                              <DataTemplate>
                                 <CheckBox Style="{StaticResource EditorCheckBox}" 
                                           IsChecked="{Binding CanCreate, UpdateSourceTrigger=PropertyChanged}" 
                                           HorizontalAlignment="Center"/>
                              </DataTemplate>
                           </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Modification" Width="110">
                           <DataGridTemplateColumn.CellTemplate>
                              <DataTemplate>
                                 <CheckBox Style="{StaticResource EditorCheckBox}" 
                                           IsChecked="{Binding CanUpdate, UpdateSourceTrigger=PropertyChanged}" 
                                           HorizontalAlignment="Center"/>
                              </DataTemplate>
                           </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                        <DataGridTemplateColumn Header="Suppression" Width="110">
                           <DataGridTemplateColumn.CellTemplate>
                              <DataTemplate>
                                 <CheckBox Style="{StaticResource EditorCheckBox}" 
                                           IsChecked="{Binding CanDelete, UpdateSourceTrigger=PropertyChanged}" 
                                           HorizontalAlignment="Center"/>
                              </DataTemplate>
                           </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>


                     </DataGrid.Columns>

                  </DataGrid>

               </Grid>

            </ScrollViewer>
         </Grid>
      </Border>
   </Grid>
</UserControl>
