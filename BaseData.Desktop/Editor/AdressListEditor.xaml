<UserControl x:Class="BaseData.Desktop.Editor.AdressListEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BaseData.Desktop.Editor"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls;assembly=OtherSideCore.Wpf"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls;assembly=OtherSideCore.Wpf"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions;assembly=OtherSideCore.Wpf" 
             xmlns:list="clr-namespace:OtherSideCore.Wpf.UserControls.List;assembly=OtherSideCore.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
   <Grid>
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto" />
         <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <list:EmptyListIndicator DataContext="{Binding Roots}"
                               EmptyListIndicator_Text="Aucune adresse enregistrée"
                               Margin="0,0,0,8" />

      <ItemsControl ItemsSource="{Binding Roots}">
         <ItemsControl.ItemTemplate>
            <DataTemplate>

               <Border Style="{StaticResource ListBorderStyle}"
                       Margin="0,0,0,8">

                  <Grid>
                     <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                     </Grid.RowDefinitions>

                     <ToggleButton Grid.Row="0" 
                                   Style="{StaticResource CardHeaderToggleButton}" 
                                   IsChecked="{Binding DomainObjectViewModel.IsExpanded}">
                        <ToggleButton.Content>
                           <StackPanel Orientation="Horizontal">

                              <osc_customcontrols:SvgViewer SvgViewer_ImageGeometry="{StaticResource icon_map-marker-radius}" 
                                                            SvgViewer_ImageWidth="20" 
                                                            SvgViewer_ImageColor="{StaticResource Green_Dark}" />

                              <TextBlock Margin="8,0,0,0" Text="{Binding DomainObjectViewModel.Label}" />

                           </StackPanel>
                        </ToggleButton.Content>
                     </ToggleButton>

                     <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="0,8,0,0"
                           Visibility="{Binding DomainObjectViewModel.IsExpanded, Converter={StaticResource BoolToVisibleOrCollapsed}}">
                        <Grid.ColumnDefinitions>
                           <ColumnDefinition Width="Auto" />
                           <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                           <RowDefinition Height="Auto" />
                           <RowDefinition Height="Auto" />
                           <RowDefinition Height="Auto" />
                           <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <osc_customcontrols:SvgViewer Grid.Row="0" Grid.Column="0" SvgViewer_ImageGeometry="{StaticResource icon_home-outline}" SvgViewer_ImageWidth="16" SvgViewer_ImageColor="{StaticResource Green}" />
                        <osc_customcontrols:SvgViewer Grid.Row="1" Grid.Column="0" SvgViewer_ImageGeometry="{StaticResource icon_map-marker-outline}" SvgViewer_ImageWidth="16" SvgViewer_ImageColor="{StaticResource Green}" />

                        <osc_customcontrols:ClickSelectTextBox Grid.Row="0" Grid.Column="1" Text="{Binding DomainObjectViewModel.Label, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorClickSelectTextBox}" Margin="8,2,0,2" />
                        <osc_customcontrols:ClickSelectTextBox Grid.Row="1" Grid.Column="1" Text="{Binding DomainObjectViewModel.AdressDescription, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorClickSelectTextBox}" Margin="8,2,0,2" />

                        <osc_customcontrols:ClickSelectSearchTextBox Grid.Row="2" Grid.Column="1" 
                                                                     Text="{Binding DomainObjectViewModel.PostalCode, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" 
                                                                     Style="{StaticResource EditorClickSelectSearchTextBox}" 
                                                                     ClickSelectSearchTextBox_SearchCommand="{Binding DomainObjectEditorViewModel.PostalCodeSelectorViewModel.DisplaySelectorAsyncCommand}"
                                                                     ClickSelectSearchTextBox_Watermark="Recherchez une localité pour l'associer"
                                                                     Margin="8,2,0,2" />


                        <StackPanel Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal" Margin="0,8,0,0">
                           <osc_customcontrols:SvgImageButton Width="24" Height="24"
                                                              BorderThickness="0"
                                                              SvgImageButton_IconGeometry="{StaticResource icon_trash-can-outline}"
                                                              SvgImageButton_ImageSize="16"
                                                              Command="{Binding DomainObjectEditorViewModel.DeleteAsyncCommand}"
                                                              CommandParameter="{Binding DomainObjectViewModel}" />
                        </StackPanel>

                     </Grid>


                  </Grid>
               </Border>

            </DataTemplate>
         </ItemsControl.ItemTemplate>
      </ItemsControl>

      <osc_customcontrols:SvgImageTextButton Grid.Row="1" Height="32"
                                             HorizontalAlignment="Right"
                                             Style="{StaticResource SvgImageTextButtonDark}"  
                                             HorizontalContentAlignment="Center"
                                             SvgImageTextButton_IconGeometry="{StaticResource icon_plus}"
                                             SvgImageTextButton_ImageSize="20"
                                             SvgImageTextButton_Text="Nouvelle adresse"
                                             Command="{Binding CreateDefaultRootNodeAsyncCommand}" />
   </Grid>
</UserControl>
