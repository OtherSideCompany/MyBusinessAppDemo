<UserControl x:Class="BaseData.Desktop.Editor.NoteListEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BaseData.Desktop.Editor"
             xmlns:osc_usercontrols="clr-namespace:OtherSideCore.Wpf.UserControls;assembly=OtherSideCore.Wpf"
             xmlns:osc_customcontrols="clr-namespace:OtherSideCore.Wpf.CustomControls;assembly=OtherSideCore.Wpf"
             xmlns:osc_extensions="clr-namespace:OtherSideCore.Wpf.Extensions;assembly=OtherSideCore.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
   <Grid>
      <Grid.RowDefinitions>
         <RowDefinition Height="Auto" />
         <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <ItemsControl Grid.Row="0"
                    ItemsSource="{Binding Roots}">
         <ItemsControl.ItemTemplate>
            <DataTemplate>
               <Border Style="{StaticResource ListBorderStyle}" Margin="0,0,0,8">
                  <Grid>
                     <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                     </Grid.RowDefinitions>
                     <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                     </Grid.ColumnDefinitions>

                     <TextBlock Text="{Binding DomainObjectViewModel.ModificationDescription}" Style="{StaticResource PropertyLabelTextBlock}" VerticalAlignment="Center" Margin="4,0,0,0" FontSize="10"/>

                     <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Height="Auto">
                        <Border.Style>
                           <Style TargetType="{x:Type Border}" BasedOn="{StaticResource EditableTextBoxBorder}">
                              <Style.Triggers>
                                 <DataTrigger Binding="{Binding DomainObjectViewModel.IsEditingComment}" Value="False">
                                    <Setter Property="BorderThickness" Value="0" />
                                 </DataTrigger>
                              </Style.Triggers>
                           </Style>
                        </Border.Style>
                        <osc_customcontrols:ClickSelectTextBox Text="{Binding DomainObjectViewModel.Text, UpdateSourceTrigger=PropertyChanged}" 
                                                               Margin="4"
                                                               TextWrapping="Wrap" 
                                                               AcceptsReturn="True"
                                                               IsReadOnly="{Binding DomainObjectViewModel.IsEditingComment, Converter={StaticResource BoolInverter}}"/>
                     </Border>


                     <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="4,0,0,0">

                        <Border Visibility="{Binding DomainObjectViewModel.IsEditingComment, Converter={StaticResource BoolToVisibleOrCollapsed}, ConverterParameter=invert}">
                           <osc_customcontrols:SvgImageButton SvgImageButton_ImageSize="16" Width="24" Height="24" BorderThickness="0"
                                                               SvgImageButton_IconGeometry="{StaticResource icon_pencil-outline}" 
                                                               Command="{Binding DomainObjectViewModel.EditNoteCommand}"
                                                               Visibility="{Binding RelativeSource={RelativeSource Self}, Path=IsEnabled, Converter={StaticResource BoolToVisibleOrCollapsed}}" />
                        </Border>

                        <osc_customcontrols:SvgImageButton SvgImageButton_ImageSize="16" Width="24" Height="24" BorderThickness="0"
                                                            SvgImageButton_IconGeometry="{StaticResource icon_trash-can-outline}" 
                                                            Command="{Binding DomainObjectEditorViewModel.DeleteAsyncCommand}"
                                                            CommandParameter="{Binding DomainObjectViewModel}"
                                                            Visibility="{Binding RelativeSource={RelativeSource Self}, Path=IsEnabled, Converter={StaticResource BoolToVisibleOrCollapsed}}" />
                     </StackPanel>

                  </Grid>
               </Border>
            </DataTemplate>
         </ItemsControl.ItemTemplate>

      </ItemsControl>

      <Border Grid.Row="1" Style="{StaticResource ListBorderStyle}" MinHeight="32" VerticalAlignment="Top">
         <Grid>
            <Grid.ColumnDefinitions>
               <ColumnDefinition Width="*" />
               <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <osc_customcontrols:ClickSelectTextBox Grid.Column="0" Margin="8,0,8,0"
                                                   ClickSelectTextBox_Watermark="Ajouter une note" 
                                                   Text="{Binding NewNoteText, UpdateSourceTrigger=PropertyChanged}"
                                                   PreviewKeyDown="AddNoteClickSelectTextBox_PreviewKeyDown"/>

            <osc_customcontrols:SvgImageButton Grid.Column="1" Margin="4" Width="28" Height="28" Cursor="Hand"
                                               SvgImageButton_IconGeometry="{StaticResource icon_send}"
                                               BorderThickness="0"
                                               Command="{Binding CreateNewNoteAsyncCommand}" />
         </Grid>
      </Border>

   </Grid>
</UserControl>
