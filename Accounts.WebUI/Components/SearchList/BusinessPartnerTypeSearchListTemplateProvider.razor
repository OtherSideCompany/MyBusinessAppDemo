@using Accounts.Contracts
@using MudBlazor
@using BusinessAppFramework.Application.Interfaces
@using WebUI.Components.SearchList
@using Search.Contracts.SearchResults
@using BusinessAppFramework.WebUI.Components.SearchList

@implements ISearchListTemplateProvider<BusinessPartnerTypeSearchResult>

@inject ILocalizedStringService LocalizedStringService

@code {
    public SearchListTemplate<BusinessPartnerTypeSearchResult> Template => new()
    {
        DataGridColumns = @<text>
            <PropertyColumn T="BusinessPartnerTypeSearchResult" TProperty="string" Property="x => x.Name" Title="@LocalizedStringService.Get(AccountsContracts.BusinessPartner_BusinessPartnerTypeName)" />
        </text>
    };
}